# Files and directories excluded from the WP.org distribution ZIP.
# Included: astrologer-api.php, src/, build/, blocks/*/build/, blocks/*/block.json,
#          blocks/*/render.php, blocks/*/style.css, patterns/, templates/,
#          languages/, vendor/ (composer production deps), readme.txt, assets/wporg/,
#          uninstall.php.

# Legacy MVP reference
_legacy/

# Development node_modules
node_modules/

# TypeScript/React source (compiled to build/)
admin-src/
interactivity-src/

# Block source files (compiled to blocks/*/build/)
blocks/*/edit.tsx
blocks/*/edit.ts
blocks/*/view.tsx
blocks/*/view.ts
blocks/*/index.tsx
blocks/*/index.ts

# Tests
tests/
.phpunit.result.cache/
coverage/

