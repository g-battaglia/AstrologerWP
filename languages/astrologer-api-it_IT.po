#. Plugin Name of the plugin
#: astrologer-api.php
msgid "Astrologer API"
msgstr "Astrologer API"

#. Description of the plugin
#: astrologer-api.php
msgid "Official WordPress plugin for the Astrologer API — birth charts, synastry, transits, moon phases and more via RapidAPI."
msgstr "Plugin WordPress ufficiale per l'Astrologer API — temi natali, sinastria, transiti, fasi lunari e altro tramite RapidAPI."

#: src/Rest/AbstractController.php
msgid "Insufficient permissions."
msgstr "Permessi insufficienti."

#: src/Rest/AbstractController.php
msgid "Too many requests. Please try again later."
msgstr "Troppe richieste. Riprova più tardi."

#: src/Blocks/BlockCategory.php
msgid "Astrology"
msgstr "Astrologia"

#: src/Rest/Controllers/MoonPhaseController.php
msgid "Both start_date and end_date are required."
msgstr "Sono obbligatori sia start_date che end_date."

#: src/Rest/Controllers/MoonPhaseController.php
msgid "Moon phase name (new, first-quarter, full, last-quarter)."
msgstr "Nome della fase lunare (new, first-quarter, full, last-quarter)."

#: src/Admin/HelpTabsProvider.php
msgid "Astrologer API integrates professional astrology calculations into your WordPress site. Configure your API credentials and preferences from this page."
msgstr "Astrologer API integra calcoli astrologici professionali nel tuo sito WordPress. Configura le credenziali API e le preferenze da questa pagina."

#: src/Admin/HelpTabsProvider.php
msgid "Chart access is controlled by custom capabilities. Administrators can manage all charts, while other roles may be limited to viewing or editing their own charts."
msgstr "L'accesso ai temi è controllato da capacità personalizzate. Gli amministratori possono gestire tutti i temi, mentre altri ruoli possono essere limitati alla visualizzazione o modifica dei propri."

#: src/Admin/HelpTabsProvider.php
msgid "Charts are custom post types that store birth data and calculated astrological information. Each chart includes date, time, and location of birth."
msgstr "I temi sono custom post type che memorizzano i dati di nascita e le informazioni astrologiche calcolate. Ogni tema include data, ora e luogo di nascita."

#: src/Admin/HelpTabsProvider.php
msgid "Choose your preferred astrological school: Modern Western, Traditional, Vedic, or Uranian. This affects house systems, aspect orbs, and available features."
msgstr "Scegli la scuola astrologica preferita: Occidentale Moderna, Tradizionale, Vedica o Uraniana. Questo influenza i sistemi di case, gli orbi degli aspetti e le funzionalità disponibili."

#: src/Admin/HelpTabsProvider.php
msgid "Enter your RapidAPI key and GeoNames username to connect to the Astrologer API. You can obtain a key from the RapidAPI marketplace."
msgstr "Inserisci la tua chiave RapidAPI e il nome utente GeoNames per connetterti all'Astrologer API. Puoi ottenere una chiave dal marketplace RapidAPI."

#: src/Admin/HelpTabsProvider.php
msgid "If the API connection test fails, verify your API key is active, your server can make outbound HTTPS requests, and your RapidAPI subscription is current."
msgstr "Se il test di connessione API fallisce, verifica che la tua chiave API sia attiva, che il server possa effettuare richieste HTTPS in uscita e che l'abbonamento RapidAPI sia corrente."

#: src/Admin/HelpTabsProvider.php
msgid "The setup wizard guides you through initial configuration: entering your API key, choosing an astrological school, and setting your language and UI preferences."
msgstr "La procedura guidata ti accompagna nella configurazione iniziale: inserimento della chiave API, scelta della scuola astrologica e impostazione delle preferenze di lingua e interfaccia."

