# ============================================================
# AstrologerWP - Environment Configuration
# Copy to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# --- Required API Credentials ---
# Get your API key at: https://rapidapi.com/gbattaglia/api/astrologer/pricing
ASTROLOGER_API_KEY=

# Get a free username at: http://www.geonames.org/login
GEONAMES_USERNAME=

# --- Custom API Endpoint (Optional) ---
# Override to test against a local API instance.
# Leave empty to use the default RapidAPI endpoint.
# Example: http://host.docker.internal:8000 (Docker)
#          http://host.internal:8000         (Apple Container)
ASTROLOGER_WP_API_BASE_URL=

# --- WordPress Settings ---
WP_PORT=8080
WP_ADMIN_USER=admin
WP_ADMIN_PASSWORD=admin
WP_ADMIN_EMAIL=admin@test.local

# --- Chart Defaults ---
CHART_THEME=classic
CHART_STYLE=classic
CHART_LANGUAGE=EN
ZODIAC_TYPE=Tropical
HOUSES_SYSTEM=P
PERSPECTIVE_TYPE=Apparent Geocentric
