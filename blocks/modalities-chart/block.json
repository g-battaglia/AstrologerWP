{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "astrologer-api/modalities-chart",
	"title": "Modalities Chart",
	"category": "astrology",
	"icon": "chart-bar",
	"description": "Bar chart for modalities (cardinal, fixed, mutable).",
	"keywords": [ "astrologer", "modalities", "chart", "cardinal", "fixed", "mutable" ],
	"textdomain": "astrologer-api",
	"supports": {
		"html": false,
		"align": [ "wide", "full" ],
		"color": {
			"background": true,
			"text": true
		},
		"spacing": {
			"margin": true,
			"padding": true
		},
		"typography": {
			"fontSize": true
		}
	},
	"attributes": {
		"sourceBlockId": {
			"type": "string",
			"default": ""
		},
		"displayMode": {
			"type": "string",
			"default": "bar"
		}
	},
	"example": {
		"attributes": {
			"displayMode": "bar"
		}
	},
	"editorScript": "file:./build/edit.js",
	"style": "file:./style.css",
	"viewScriptModule": "file:./build/view.js",
	"render": "file:./render.php"
}
