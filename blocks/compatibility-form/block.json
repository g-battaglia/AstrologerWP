{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "astrologer-api/compatibility-form",
	"title": "Compatibility Form",
	"category": "astrology",
	"icon": "thumbs-up",
	"description": "Form to collect two subjects' birth data for compatibility score calculation.",
	"keywords": [ "astrologer", "compatibility", "form", "relationship" ],
	"textdomain": "astrologer-api",
	"supports": {
		"html": false,
		"align": [ "wide", "full" ],
		"color": {
			"background": true,
			"text": true
		},
		"spacing": {
			"margin": true,
			"padding": true
		},
		"typography": {
			"fontSize": true
		}
	},
	"attributes": {
		"uiLevel": {
			"type": "string",
			"default": "basic",
			"enum": [ "basic", "advanced", "expert" ]
		},
		"targetBlockId": {
			"type": "string",
			"default": ""
		},
		"showSaveOption": {
			"type": "boolean",
			"default": false
		},
		"preset": {
			"type": "string",
			"default": "auto"
		},
		"redirectAfterSubmit": {
			"type": "string",
			"default": ""
		},
		"twoSubjectLayout": {
			"type": "string",
			"default": "stacked",
			"enum": [ "stacked", "side-by-side" ]
		}
	},
	"example": {
		"attributes": {
			"uiLevel": "basic"
		}
	},
	"editorScript": "file:./build/edit.js",
	"style": "file:./style.css",
	"viewScriptModule": "file:./build/view.js",
	"render": "file:./render.php"
}
