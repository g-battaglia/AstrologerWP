{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "astrologer-api/positions-table",
	"title": "Positions Table",
	"category": "astrology",
	"icon": "list-view",
	"description": "Table of planet and point positions (sign, degree, house).",
	"keywords": [ "astrologer", "positions", "planets", "table" ],
	"textdomain": "astrologer-api",
	"supports": {
		"html": false,
		"align": [ "wide", "full" ],
		"color": {
			"background": true,
			"text": true
		},
		"spacing": {
			"margin": true,
			"padding": true
		},
		"typography": {
			"fontSize": true
		}
	},
	"attributes": {
		"sourceBlockId": {
			"type": "string",
			"default": ""
		},
		"displayMode": {
			"type": "string",
			"default": "table"
		}
	},
	"example": {
		"attributes": {
			"displayMode": "table"
		}
	},
	"editorScript": "file:./build/edit.js",
	"style": "file:./style.css",
	"viewScriptModule": "file:./build/view.js",
	"render": "file:./render.php"
}
