{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "astrologer-api/now-chart",
	"title": "Now Chart",
	"category": "astrology",
	"icon": "chart-pie",
	"description": "Displays the current sky chart for a location.",
	"keywords": [ "astrologer", "now", "sky", "chart" ],
	"textdomain": "astrologer-api",
	"supports": {
		"html": false,
		"align": [ "wide", "full" ],
		"color": {
			"background": true,
			"text": true
		},
		"spacing": {
			"margin": true,
			"padding": true
		},
		"typography": {
			"fontSize": true
		}
	},
	"attributes": {
		"sourceBlockId": {
			"type": "string",
			"default": ""
		},
		"showSvg": {
			"type": "boolean",
			"default": true
		},
		"showPositions": {
			"type": "boolean",
			"default": true
		},
		"showAspects": {
			"type": "boolean",
			"default": false
		},
		"chartTheme": {
			"type": "string",
			"default": "classic",
			"enum": [ "classic", "dark", "light" ]
		},
		"theme": {
			"type": "string",
			"default": "wheel"
		}
	},
	"example": {
		"attributes": {
			"chartTheme": "classic"
		}
	},
	"editorScript": "file:./build/edit.js",
	"style": "file:./style.css",
	"viewScriptModule": "file:./build/view.js",
	"render": "file:./render.php"
}
